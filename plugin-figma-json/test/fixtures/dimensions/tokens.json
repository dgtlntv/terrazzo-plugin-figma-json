{
  "spacing": {
    "$type": "dimension",
    "none": {
      "$value": { "value": 0, "unit": "px" }
    },
    "xs": {
      "$value": { "value": 4, "unit": "px" }
    },
    "sm": {
      "$value": { "value": 8, "unit": "px" }
    },
    "md": {
      "$value": { "value": 16, "unit": "px" }
    },
    "lg": {
      "$value": { "value": 24, "unit": "px" }
    },
    "xl": {
      "$value": { "value": 32, "unit": "px" }
    },
    "rem-half": {
      "$value": { "value": 0.5, "unit": "rem" },
      "$description": "Half rem unit (8px at 16px base)"
    },
    "rem-one": {
      "$value": { "value": 1, "unit": "rem" },
      "$description": "One rem unit (16px at 16px base)"
    },
    "rem-two": {
      "$value": { "value": 2, "unit": "rem" },
      "$description": "Two rem units (32px at 16px base)"
    },
    "rem-fractional": {
      "$value": { "value": 1.25, "unit": "rem" },
      "$description": "Fractional rem (20px at 16px base)"
    }
