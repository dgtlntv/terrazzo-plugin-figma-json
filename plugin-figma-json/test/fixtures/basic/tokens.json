{
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.2, 0.4, 0.8]
      },
      "$description": "Primary brand color"
    },
    "secondary": {
      "$value": {
        "colorSpace": "hsl",
        "components": [210, 50, 60],
        "alpha": 0.9
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "small": {
      "$value": { "value": 8, "unit": "px" }
    },
    "medium": {
      "$value": { "value": 16, "unit": "px" }
    },
    "large": {
      "$value": { "value": 1.5, "unit": "rem" }
    }
  },
  "animation": {
    "$type": "duration",
    "fast": {
      "$value": { "value": 150, "unit": "ms" }
    },
    "slow": {
      "$value": { "value": 0.5, "unit": "s" }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "primary": {
        "$value": ["Inter", "Helvetica", "sans-serif"]
      },
      "mono": {
        "$value": "JetBrains Mono"
      }
    },
    "weight": {
      "$type": "fontWeight",
      "normal": {
        "$value": 400
      },
      "bold": {
        "$value": "bold"
      }
    }
  },
  "lineHeight": {
    "$type": "number",
    "tight": {
      "$value": 1.25
    },
    "normal": {
      "$value": 1.5
    }
  }
}
