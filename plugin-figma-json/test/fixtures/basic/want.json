{
  "animation": {
    "fast": {
      "$type": "duration",
      "$value": {
        "value": 0.15,
        "unit": "s"
      }
    },
    "slow": {
      "$type": "duration",
      "$value": {
        "value": 0.5,
        "unit": "s"
      }
    }
  },
  "color": {
    "primary": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          0.4,
          0.8
        ],
        "alpha": 1
      },
      "$description": "Primary brand color"
    },
    "secondary": {
      "$type": "color",
      "$value": {
        "colorSpace": "hsl",
        "components": [
          210,
          50,
          60
        ],
        "alpha": 0.9
      }
    }
  },
  "font": {
    "family": {
      "mono": {
        "$type": "fontFamily",
        "$value": "JetBrains Mono"
      },
      "primary": {
        "$type": "fontFamily",
        "$value": "Inter"
      }
    },
    "weight": {
      "bold": {
        "$type": "number",
        "$value": 700
      },
      "normal": {
        "$type": "number",
        "$value": 400
      }
    }
  },
  "lineHeight": {
    "normal": {
      "$type": "number",
      "$value": 1.5
    },
    "tight": {
      "$type": "number",
      "$value": 1.25
    }
  },
  "spacing": {
    "large": {
      "$type": "dimension",
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "medium": {
      "$type": "dimension",
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "small": {
      "$type": "dimension",
      "$value": {
        "value": 8,
        "unit": "px"
      }
    }
  }
}