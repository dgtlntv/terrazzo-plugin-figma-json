{
  "border": {
    "default": {
      "color": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [
            0.8,
            0.8,
            0.8
          ],
          "alpha": 1
        },
        "$description": "Default border style"
      },
      "width": {
        "$type": "dimension",
        "$value": {
          "value": 1,
          "unit": "px"
        },
        "$description": "Default border style"
      }
    },
    "thick": {
      "color": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [
            0,
            0,
            0
          ],
          "alpha": 1
        }
      },
      "width": {
        "$type": "dimension",
        "$value": {
          "value": 2,
          "unit": "px"
        }
      }
    }
  }
}