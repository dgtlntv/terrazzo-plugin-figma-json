{
  "border": {
    "$type": "border",
    "default": {
      "$value": {
        "color": { "colorSpace": "srgb", "components": [0.8, 0.8, 0.8] },
        "width": { "value": 1, "unit": "px" },
        "style": "solid"
      },
      "$description": "Default border style"
    },
    "thick": {
      "$value": {
        "color": { "colorSpace": "srgb", "components": [0, 0, 0] },
        "width": { "value": 2, "unit": "px" },
        "style": "solid"
      }
    }
  }
}
