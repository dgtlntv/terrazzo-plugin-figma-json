{
  "typography": {
    "$type": "typography",
    "heading": {
      "large": {
        "$value": {
          "fontFamily": "Inter",
          "fontSize": { "value": 32, "unit": "px" },
          "fontWeight": 700,
          "lineHeight": 1.2,
          "letterSpacing": { "value": -0.5, "unit": "px" }
        },
        "$description": "Large heading style"
      },
      "medium": {
        "$value": {
          "fontFamily": ["Roboto", "Helvetica", "sans-serif"],
          "fontSize": { "value": 24, "unit": "px" },
          "fontWeight": "bold",
          "lineHeight": 1.3,
          "letterSpacing": { "value": 0, "unit": "px" }
        }
      }
    },
    "body": {
      "default": {
        "$value": {
          "fontFamily": "Inter",
          "fontSize": { "value": 16, "unit": "px" },
          "fontWeight": 400,
          "lineHeight": 1.5,
          "letterSpacing": { "value": 0, "unit": "px" }
        },
        "$description": "Default body text"
      },
      "small": {
        "$value": {
          "fontFamily": "Inter",
          "fontSize": { "value": 0.875, "unit": "rem" },
          "fontWeight": 400,
          "lineHeight": 1.4,
          "letterSpacing": { "value": 0, "unit": "px" }
        }
      }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "primary": {
        "$value": "Inter"
      }
    }
  }
}
