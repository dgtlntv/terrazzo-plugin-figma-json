{
  "color": {
    "$type": "color",
    "red": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.9, 0.2, 0.2]
      }
    },
    "blue": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.2, 0.4, 0.9]
      }
    },
    "green": {
      "$value": {
        "colorSpace": "srgb",
        "components": [0.2, 0.8, 0.3]
      }
    }
  },
  "semantic": {
    "$type": "color",
    "danger": {
      "$value": "{color.red}",
      "$description": "Alias to red"
    },
    "primary": {
      "$value": "{color.blue}",
      "$description": "Alias to blue"
    },
    "success": {
      "$value": "{color.green}",
      "$description": "Alias to green"
    }
  },
  "spacing": {
    "$type": "dimension",
    "base": {
      "$value": { "value": 8, "unit": "px" }
    },
    "double": {
      "$value": "{spacing.base}",
      "$description": "Alias to base spacing"
    }
  },
  "numbers": {
    "$type": "number",
    "ratio": {
      "$value": 1.618
    },
    "golden": {
      "$value": "{numbers.ratio}",
      "$description": "Alias to ratio"
    }
  }
}
